global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s

defaults
    log global
    mode http

    option httplog
    option dontlognull

    timeout connect 5s
    timeout client  50s
    timeout server  50s

    retries 3


frontend http_front
    bind *:{{ haproxy_frontend_port }}
    default_backend web_backends


backend web_backends
    balance roundrobin

{% for host in groups['apache'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:80 check
{% endfor %}

{% for host in groups['nginx'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:80 check
{% endfor %}


listen stats
    bind *:{{ haproxy_stats_port }}

    stats enable
    stats uri {{ haproxy_stats_uri }}
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats refresh 10s


frontend prometheus_metrics
    bind *:8085
    mode http
    no log

    http-request use-service prometheus-exporter if { path {{ haproxy_metrics_uri }} }
